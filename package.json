{
  "name": "blog-app",
  "version": "1.0.0",
  "description": "Minimal MERN stack blog app",
  "main": "index.js",
  "scripts": {
    "install-all": "npm install && npm install --prefix server && npm install --prefix client --legacy-peer-deps",
    "build": "npm run build-client",
    "start": "concurrently \"npm run start-server\" \"npm run start-client\"",
    "build-client": "npm run build --prefix client",
    "start-client": "npm run dev --prefix client",
    "start-server": "npm run dev --prefix server"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}